# Docker Model Runner (OpenAI-compatible endpoint)
DMR_BASE_URL=http://localhost:12434/engines/v1
DMR_API_KEY=local-dummy

# Models
FOREMAN_MODEL=docker.io/ai/deepseek-r1-distill-llama:70B-Q4_K_M
CODER_MODEL=docker.io/ai/qwen3-coder-next:latest

# Output directory (default: ./factory_out)
# FACTORY_OUTPUT_DIR=/path/to/output

# Retry limits
# MAX_GENERATE_ATTEMPTS=2
# MAX_FIX_ATTEMPTS=4
